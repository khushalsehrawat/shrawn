# =========================================================
# Shrawn Local Development Environment Example
# Copy this file to .env and change values if needed.
# Never commit your real .env file.
# =========================================================

# PostgreSQL
POSTGRES_DB=shrawn
POSTGRES_USER=shrawn
POSTGRES_PASSWORD=shrawn
POSTGRES_PORT=5432

# Spring datasource values
DB_URL=jdbc:postgresql://localhost:5432/shrawn
DB_USERNAME=shrawn
DB_PASSWORD=shrawn

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring Boot
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# Frontend
FRONTEND_URL=http://localhost:5173

# Local file storage
LOCAL_STORAGE_PATH=./data/uploads